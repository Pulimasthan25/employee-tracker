rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: checks if the logged-in user is an admin
    function isAdmin() {
      return (request.auth != null && 'role' in request.auth.token && request.auth.token.role == 'admin') ||
             (request.auth != null && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // USERS collection
    // - Any logged-in user can read their own profile
    // - Only admins can read other users or write/create users
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // ACTIVITIES collection (app usage, URL tracking, time logs)
    // - Admins can read everything
    // - Employees can only read their own activity
    // - Any logged-in user can create activity (the desktop agent does this)
    // - Only admins can update or delete
    match /activities/{docId} {
      allow read:   if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // SCREENSHOTS collection
    // - Same read rule as activities
    // - Any logged-in user can upload (the desktop agent does this)
    // - Only admins can delete
    match /screenshots/{docId} {
      allow read:   if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow delete: if isAdmin();
    }

    match /shifts/{docId} {
      // Admins can read all shifts
      allow read: if request.auth != null && isAdmin();
      // Employee can read their own shifts
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Agent can create/update only its own shift docs
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // IDLE SESSIONS collection (break/idle time)
    // - Admins can read everything
    // - Employees can only read their own sessions
    // - Agent can create only for itself
    // - Only admins can update or delete
    match /idle_sessions/{docId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // AGENT STATUS collection (desktop agent metadata like version/lastSeen)
    // - Admins can read all
    // - Users can read their own
    // - Agent/user can create/update their own status doc
    // - Only admins can delete
    match /agent_status/{uid} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == uid);
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if isAdmin();
    }
  }
}
